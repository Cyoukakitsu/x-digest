# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# OpenRouter (DeepSeek)
OPENROUTER_API_KEY=

# Resend
RESEND_API_KEY=
RESEND_FROM_EMAIL=digest@yourdomain.com
RESEND_TO_EMAIL=your@email.com

# RSSHub (self-hosted)
RSSHUB_BASE_URL=https://your-rsshub-instance.com

# Security — generate with: openssl rand -hex 32
CRON_SECRET=

# App — local: http://localhost:3000, production: https://x-digest.vercel.app
NEXT_PUBLIC_APP_URL=http://localhost:3000
